# URL de connexion PostgreSQL (fournie automatiquement par Render si tu utilises render.yaml)
DATABASE_URL=postgres://user:password@localhost:5432/meridien

# Secret utilise pour signer les tokens JWT (chaine aleatoire longue)
JWT_SECRET=change-me-to-a-long-random-string

# Cles Stripe (Dashboard Stripe > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL publique du front (utilisee pour les redirections Stripe success/cancel)
CLIENT_URL=http://localhost:5173

PORT=4000
NODE_ENV=development
